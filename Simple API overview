components:
  schemas:
    Account:
      type: object
      description: |
        Username and password credentials passed inside the `Account` object

        Source discrepancy: some request tables in the manual omit `Account`, but JSON examples include it. In the EndGame request table `Account` is marked mandatory while the remark calls it optional and sportsbook-specific

        Decision: model `Account` as optional in request schemas
      required:
        - UserName
        - Password
      properties:
        UserName:
          type: string
          description: Username parameter within the Account object
          x-source-flag: Canonicalized to `Account.UserName` on 2026-04-22 per foi-canonicalization-decisions.md row 9.
        Password:
          type: string
          description: Password parameter within the Account object
    JackpotDetailsParameter:
      type: object
      properties:
        JackpotId:
          type: string
          description: Jackpot ID from the Jackpot feed if available.
        JackpotName:
          type: string
          description: Jackpot name from the Jackpot feed if available.
        CurrencyCode:
          type: string
          maxLength: 3
          description: The currency of the jackpot according to ISO.
        Amount:
          oneOf:
            - type: number
              format: double
            - type: string
          description: Jackpot contribution or win amount. Manual examples sometimes send decimals as JSON strings.
    SubTicket:
      type: object
      properties:
        SubTicketNumber:
          type: integer
          description: Serial number of the sub ticket. For a single ticket game, value should always be 1.
        SubTicketCreditAmount:
          type: number
          format: double
          description: Credit amount of the normal win of the sub ticket.
        SubTicketDebitAmount:
          type: number
          format: double
          description: Debit amount of the sub ticket.
        SubTicketPrizeMultiplier:
          type: number
          format: double
          description: Prize multiplier of the specific sub ticket.
        SubTicketJackpotAmount:
          type: number
          format: double
          description: Credit amount of the progressive win of the sub ticket.
    Taxes:
      type: object
      description: |
        Split Tax: If enabled, the requests to the operator will show what is the initial bet and what is the tax amount in different parameters
      properties:
        BetAmount:
          type: number
          format: double
          description: "The amount of the bet. Decimal value - note: manual examples sometimes send decimals as JSON strings"
        TaxAmount:
          type: number
          format: double
          description: "The amount of tax calculated. Decimal value - note: manual examples sometimes send decimals as JSON strings"
    MessageButton:
      type: object
      properties:
        Text:
          type: string
          description: Text of the button
          example: Quit Game
        Action:
          type: string
          description: "One of: quit - exit game; cashier - open cashier; history - open history; continue - close popup; link - open custom link"
          example: quit
        Link:
          type: string
          description: URL to open when action is link
          example: https://www.casino.com/myaccount/history
        LinkType:
          type: integer
          description: How the link is handled (1 = Redirect, 2 = Ajax, 3 = AjaxResponse)
          example: 1
    MessageContent:
      type: object
      properties:
        DisplayType:
          type: integer
          description: Missing in table in Manual, appears in examples only
          example: 1
        Title:
          type: string
          description: Title of the popup message
          example: Title for the popup message
        Text:
          type: string
          description: Message text. Use \\n or \\r\\n for line breaks
          example: "message. Including \\r\\n or just \\n for enter"
        Buttons:
          type: array
          description: List of buttons available for the popup
          items:
            $ref: '#/components/schemas/MessageButton'
          example:
            - Text: Quit Game
              Action: quit
            - Text: Ok
              Action: continue
            - Text: View History
              Action: link
              Link: https://www.casino.com/myaccount/history
    MessageItem:
      type: object
      example:
        DisplayType: 1
        MessageType: 1
        MessageContent:
          Title: Title for the popup message
          Text: "message. Including \\r\\n or just \\n for enter"
          Buttons:
            - Text: Quit Game
              Action: quit
            - Text: Ok
              Action: continue
            - Text: View History
              Action: link
              Link: https://www.casino.com/myaccount/history
      properties:
        DisplayType:
          type: integer
          description: 1 = Notification, 2 = Popup (intrusive)
          example: 1
        MessageType:
          type: integer
          description: 1 = Custom, 2 = Bonus wallet message, 3 = Cash wallet message
          example: 1
        MessageContent:
          $ref: '#/components/schemas/MessageContent'
    OperatorError:
      type: object
      properties:
        ErrorCode:
          type: integer
          description: Operator error code
        Balance:
          type: number
          nullable: true
          description: "Note: The balance in the error response will be returned only if possible"
        OperatorMessage:
          type: string
          nullable: true
          description: Operator error message
    AuthenticateRequest:
      type: object
      required:
        - Token
        - PlayerId
      properties:
        Account:
          allOf:
            - $ref: '#/components/schemas/Account'
          description: Operator credentials. Source request example includes Account, but the parameter table does not list it.
        Token:
          type: string
          maxLength: 1000
          description: The token of the player for a specific game. It is mapped to the vendor-side token used after EVI Authenticate.
        PlayerId:
          type: string
          maxLength: 50
          description: The unique ID of the player inside the casino system.
          x-source-flag: Canonicalized to `PlayerId` on 2026-04-22 per foi-canonicalization-decisions.md row 1.
        PlatformType:
          type: integer
          enum:
            - 1
            - 2
            - 3
          description: The game platform of the game. 1 = Desktop, 2 = Mobile, 3 = CrossPlatform.
        BrandId:
          type: string
          maxLength: 8
          nullable: true
          description: Used to differentiate brands on the operator side when operators use the same account in the aggregator system.
    AuthenticateResponse:
      oneOf:
        - $ref: '#/components/schemas/AuthenticateSuccessResponse'
        - $ref: '#/components/schemas/AuthenticateErrorResponse'
    AuthenticateSuccessResponse:
      type: object
      required:
        - Balance
        - Error
      properties:
        Balance:
          type: number
          format: double
          description: The balance of the player. Example 100.50.
        Error:
          type: object
          nullable: true
          enum:
            - null
          description: Must be null on success responses.
        BonusBalance:
          type: number
          format: double
          nullable: true
          description: The bonus balance of the player. Example 100.50.
        FinancialMode:
          type: integer
          nullable: true
          enum:
            - 0
            - 1
            - null
          description: Financial mode. 0 = Wallet, 1 = Ecommerce. Default value is 0.
        RoundsLeft:
          type: integer
          nullable: true
          description: The number of rounds left for the player. Only relevant when FinancialMode is 1, Ecommerce mode.
        EcommerceTicketPrice:
          type: number
          format: double
          nullable: true
          description: Ticket price. Mandatory only if FinancialMode is 1, Ecommerce.
        Timestamp:
          type: string
          format: date-time
          nullable: true
          description: Date and time the operator sent the response, in ISO 8601 format.
        SecondOperatorToken:
          type: string
          maxLength: 1000
          nullable: true
          description: New game session token returned by the operator. If provided, it is used as Token in further financial calls.
        Tier:
          type: string
          nullable: true
          description: The tier optionally identifies the value segment to which the player has been assigned by the operator.
        UserSettings:
          allOf:
            - $ref: '#/components/schemas/UserSettings'
          description: Specific player parameters.
    AuthenticateErrorResponse:
      type: object
      required:
        - Error
      properties:
        Error:
          type: object
          description: Object defining the error. Object is null on success response.
          required:
            - ErrorCode
          properties:
            ErrorCode:
              type: integer
              enum:
                - 4
                - 5
                - 8
                - 10
                - 12
                - 13
                - 14
                - 15
                - 16
                - 900
            OperatorMessage:
              type: string
              nullable: true
              description: Error description. Informative, not forwarded to the game provider.
              enum:
                - AuthenticationFailed
                - TokenExpired
                - InvalidToken
                - InvalidUserId
                - AccountIsLocked
                - PlayerLimitExceededTurnover
                - PlayerLimitExceededSessionTime
                - PlayerLimitExceededSessionStake
                - PlayerLimitExceededSessionLoss
                - GeneralError
            Balance:
              type: number
              format: double
              nullable: true
              description: The balance of the player.
            BonusBalance:
              type: number
              format: double
              nullable: true
              description: The bonus balance of the player.
            RoundsLeft:
              type: integer
              nullable: true
              description: The number of rounds left for the player. Only relevant when FinancialMode is 1, Ecommerce mode.
    UserSettings:
      type: object
      properties:
        MaxBet:
          oneOf:
            - type: number
              format: double
            - type: string
          nullable: true
          description: To support UKGC maximum stake limits, operators should provide the maximum bet in the player's currency based on the player's age.
        MaxExposure:
          oneOf:
            - type: number
              format: double
            - type: string
          nullable: true
          description: The max exposure amount.
        MinBet:
          oneOf:
            - type: number
              format: double
            - type: string
          nullable: true
          description: Minimum bet amount if the game provider supports it.
        DefaultBet:
          oneOf:
            - type: number
              format: double
            - type: string
          nullable: true
          description: Default bet if the game provider supports it.
    FinancialSuccessPayload:
      type: object
      required:
        - Balance
        - TransactionId
      properties:
        Balance:
          type: number
          format: double
          description: The balance of the player
        BonusBalance:
          type: number
          format: double
          nullable: true
          description: The bonus balance of the player
        TransactionId:
          type: string
          description: A unique Transaction ID
        UsedBonusMoney:
          type: number
          format: double
          nullable: true
          description: Missing in table in Manual, appears in examples only
        ExtraData:
          type: string
          nullable: true
          description: Optional custom parameter
        RoundsLeft:
          type: integer
          nullable: true
          description: The number of rounds left for the player. Relevant only when FinancialMode is ecommerce
        ActualEcommerceTicketPrice:
          type: number
          format: double
          nullable: true
