paths:
  /Authenticate:
    post:
      tags:
        - Financial Integration
      summary: Authentication
      operationId: authenticate
      description: |
        After the player opens a game or a current game is reloaded, an authentication request is sent to the operator to validate the player's token and create or refresh a game session on the operator side.

        The mismatch between the Authenticate endpoint in FOI and EVI is by design to accommodate EVI and DVI vendor integrations.

        HTTP code of an error response should always be 200.

        The aggregator calls this endpoint after vendor authentication. The operator validates player and session context and returns data needed for gameplay and financial calls.
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/AuthenticateRequest'
            examples:
              standard_authenticate:
                summary: standard authenticate request
                value:
                  Account:
                    UserName: testuser
                    Password: qweqwe1
                  Token: F3497FC0FE204EE7B50A2B11B72377BA
                  PlayerId: "20452"
                  PlatformType: 1
                  BrandId: "123"
      responses:
        "200":
          description: HTTP 200 OK
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/AuthenticateResponse'
              examples:
                success:
                  summary: successful authenticate response
                  value:
                    Balance: 505116.1
                    BonusBalance: 0.0
                    FinancialMode: 0
                    RoundsLeft: 0
                    Error: null
                    Timestamp: "2025-10-13T01:35:12Z"
                    UserSettings:
                      MaxBet: "5.0"
                      MaxExposure: "0.0"
                      MinBet: "0.0"
                      DefaultBet: "0.0"
                error_authentication_failed:
                  summary: 4 - authentication failed
                  value:
                    Error:
                      ErrorCode: 4
                      OperatorMessage: AuthenticationFailed
                error_token_expired:
                  summary: 5 - token expired
                  value:
                    Error:
                      ErrorCode: 5
                      OperatorMessage: TokenExpired
                error_invalid_token:
                  summary: 8 - invalid token
                  value:
                    Error:
                      ErrorCode: 8
                      OperatorMessage: InvalidToken
                error_invalid_user_id:
                  summary: 10 - invalid user id
                  value:
                    Error:
                      ErrorCode: 10
                      OperatorMessage: InvalidUserId
                error_account_is_locked:
                  summary: 12 - account is locked
